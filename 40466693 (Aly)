-- Report Title: Performance by Credential Type for Students with Disabilities
-- Business Question: Which qualification level do disabled students struggle with most?
-- Why this report is useful: Helps allocate support resources to the right qualification levels
-- Tables used: Subject, Test, Test_Student, Student_Disability_Support

SELECT 
    sub.Credential_Type,
    COUNT(DISTINCT ts.Student_ID) AS Total_Students,
    ROUND(AVG(ts.Score), 2) AS Average_Score,
    ROUND(100 * SUM(CASE WHEN ts.Score >= t.Pass_Marks THEN 1 ELSE 0 END) / COUNT(*), 2) AS Pass_Rate
FROM Subject sub
INNER JOIN Test t ON sub.Subject_ID = t.Subject_ID
INNER JOIN Test_Student ts ON t.Test_ID = ts.Test_ID
INNER JOIN Student_Disability_Support sds ON ts.Student_ID = sds.Student_ID
GROUP BY sub.Credential_Type
ORDER BY Average_Score DESC;

