-- Report Title: Teacher Workload for SEN Classes
-- Business Question: How many classes supporting students with disabilities does each teacher have?
-- Why this report is useful: Helps identify if SEN support workload is fairly distributed
-- Tables used: Teacher, Teacher_Class, Class, Student_Class, Student_Disability_Support

SELECT 
    t.Title,
    t.Forename,
    t.Surname,
    COUNT(DISTINCT tc.Class_ID) AS Total_Classes,
    COUNT(DISTINCT sds.Student_ID) AS Total_SEN_Students
FROM Teacher t
LEFT JOIN Teacher_Class tc ON t.Teacher_ID = tc.Teacher_ID
LEFT JOIN Student_Class sc ON tc.Class_ID = sc.Class_ID
LEFT JOIN Student_Disability_Support sds ON sc.Student_ID = sds.Student_ID
GROUP BY t.Teacher_ID, t.Title, t.Forename, t.Surname
ORDER BY Total_SEN_Students DESC;